# Flask session secret key
SECRET_KEY=replace_with_a_random_secret

# Access password for the web page and protected API routes
# Leave empty to disable password verification
ACCESS_PASSWORD=

# Upload root directory
# Absolute path is recommended; relative paths are resolved from the project directory
UPLOAD_FOLDER=Public/uploads

# Startup mode: lan or local
# lan    -> bind 0.0.0.0 for access from other devices on the LAN
# local  -> bind 127.0.0.1 for local-only access
STARTUP_MODE=lan

# Optional explicit bind host and port overrides
# HOST=
# PORT=8900

# Optional aliases supported by the app
# FLASK_SECRET_KEY=
# UPLOAD_PASSWORD=
# PAGE_PASSWORD=
# UPLOAD_DIR=
# UPLOAD_PATH=
